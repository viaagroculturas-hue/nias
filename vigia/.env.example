# .env.example — copie para .env e preencha os valores reais
# NUNCA commite o .env real
# Gere segredos com: python -c "import secrets; print(secrets.token_hex(32))"
# Em produção: use Railway Secrets (não variáveis de ambiente)

# ── Banco de dados ────────────────────────────────────────────────
# Railway injeta DATABASE_URL automaticamente — use essa variável.
DATABASE_URL=postgresql+asyncpg://vigia:senha@localhost:5432/vigia_db
POSTGRES_USER=vigia
POSTGRES_DB=vigia_db
POSTGRES_PASSWORD=troque_esta_senha

# ── Cache / Fila ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────
JWT_SECRET=gere_um_segredo_forte_aqui_32_bytes_hex

# ── IA — Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Satélite — Google Earth Engine ───────────────────────────────
# Deixe em branco para usar NDVI simulado em desenvolvimento.
GEE_SERVICE_ACCOUNT=vigia@meu-projeto.iam.gserviceaccount.com
GEE_KEY_FILE=./gee_key.json

# ── Notificações — Twilio (WhatsApp + SMS) ───────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+15005550006

# ── Notificações — Z-API (alternativa BR WhatsApp) ───────────────
# Deixe em branco se usar Twilio
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=

# ── Destinatários — separados por vírgula ─────────────────────────
NOTIFICACAO_DESTINOS_WHATSAPP=+5511999999999
NOTIFICACAO_DESTINOS_SMS=+5511999999999

# ── Monitoramento — Sentry ───────────────────────────────────────
# Deixe em branco para desativar. Só inicializa em APP_ENV=production.
SENTRY_DSN=

# ── App ───────────────────────────────────────────────────────────
APP_ENV=production
APP_URL=https://vigia.seudominio.com
API_URL=https://api.vigia.seudominio.com
RELATORIO_HORA=05:30
RELATORIO_TIMEZONE=America/Sao_Paulo

# ── Frontend (Next.js build-time vars) ───────────────────────────
NEXT_PUBLIC_API_URL=https://api.vigia.seudominio.com
NEXT_PUBLIC_WS_URL=wss://api.vigia.seudominio.com
